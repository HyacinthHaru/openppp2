{
    "prefixes": ":10000",
    "path": "/ppp/webhook",
    "key": "replace-with-server-backend-key",
    "admin": {
        "token": "",
        "path": "/admin/",
        "public-base-url": "https://manager.example.com"
    },
    "interfaces": {
        "consumer-reload": "/ppp/consumer/reload",
        "consumer-load": "/ppp/consumer/load",
        "consumer-set": "/ppp/consumer/set",
        "consumer-new": "/ppp/consumer/new",
        "server-get": "/ppp/server/get",
        "server-all": "/ppp/server/all",
        "server-load": "/ppp/server/load"
    },
    "redis": {
        "addresses": ["127.0.0.1:26379"],
        "master": "mymaster",
        "db": 0,
        "password": ""
    },
    "database": {
        "max-open-conns": 100,
        "max-idle-conns": 5,
        "conn-max-life-time": 3600,
        "master": {
            "host": "127.0.0.1",
            "port": 3306,
            "user": "openppp2",
            "password": "replace-me",
            "db": "ppp"
        },
        "slaves": []
    },
    "concurrency-control": {
        "node-websocket-timeout": 20,
        "node-mysql-query": 1,
        "user-mysql-query": 1,
        "user-cache-timeout": 3600,
        "user-archive-timeout": 20
    }
}
